import React, { useMemo } from 'react';
import Plot from 'react-plotly.js';
import { calculatePRRoots, getLnPhi, getMixtureAB, PRParams, SUBSTANCES } from '../lib/eos';

const R_GAS = 0.08206; // L*atm/(mol*K)
const ATM_TO_MPA = 0.101325;
const MPA_TO_ATM = 1 / ATM_TO_MPA;

interface Plot3DProps {
  composition: { id: keyof typeof SUBSTANCES; x: number }[];
  pressureRange: { min: number; max: number };
  temperatureRange: { min: number; max: number };
  showMetastable: boolean;
  showHysteresis: boolean;
  currentT: number;
  currentP: number;
}

export default function Plot3D({ composition, pressureRange, temperatureRange, showMetastable, showHysteresis, currentT, currentP }: Plot3DProps) {
  const plotData = useMemo(() => {
    const tSteps = 80;
    const pSteps = 80;
    
    const tMin = temperatureRange.min;
    const tMax = temperatureRange.max;
    const tStepSize = (tMax - tMin) / tSteps;
    const pStepSize = (pressureRange.max - pressureRange.min) / pSteps;

    const x_P: number[] = [];
    const y_T: number[] = [];
    
    const z_Eq: (number | null)[][] = [];
    const c_Eq: (number | null)[][] = [];
    const z_Middle: (number | null)[][] = [];

    const spV_x: number[] = [];
    const spV_y: number[] = [];
    const spV_z: number[] = [];

    const spL_x: number[] = [];
    const spL_y: number[] = [];
    const spL_z: number[] = [];

    for (let j = 0; j <= pSteps; j++) {
      x_P.push(pressureRange.min + j * pStepSize);
    }
    for (let i = 0; i <= tSteps; i++) {
      y_T.push(tMin + i * tStepSize);
    }

    for (let i = 0; i <= tSteps; i++) {
      const T = y_T[i];
      const { a, b } = getMixtureAB(composition, T, R_GAS);
      const params: PRParams = { a, b, R: R_GAS, T };

      const zM_row: (number | null)[] = [];
      const zE_row: (number | null)[] = [];
      const cE_row: (number | null)[] = [];

      let first3: {p: number, zL: number} | null = null;
      let last3: {p: number, zV: number} | null = null;

      for (let j = 0; j <= pSteps; j++) {
        const P_MPa = x_P[j];
        const P_atm = P_MPa * MPA_TO_ATM;
        const result = calculatePRRoots(P_atm, params);

        let zE: number | null = null;
        let cE: number | null = null; // 0 for vapor, 1 for liquid

        if (result.Z_vapor !== null && result.Z_liquid !== null) {
          const phiV = getLnPhi(result.Z_vapor, result.A, result.B);
          const phiL = getLnPhi(result.Z_liquid, result.A, result.B);

          if (phiV <= phiL) {
            zE = result.Z_vapor;
            cE = 0;
          } else {
            zE = result.Z_liquid;
            cE = 1;
          }

          if (result.Z_middle !== null) {
            if (!first3) first3 = { p: P_MPa, zL: result.Z_liquid };
            last3 = { p: P_MPa, zV: result.Z_vapor };
          }
        } else {
          if (result.Z_vapor !== null) {
            zE = result.Z_vapor;
            cE = 0;
          }
          if (result.Z_liquid !== null) {
            zE = result.Z_liquid;
            cE = 1;
          }
        }

        zE_row.push(zE);
        cE_row.push(cE);
        zM_row.push(result.Z_middle);
      }
      
      z_Eq.push(zE_row);
      c_Eq.push(cE_row);
      z_Middle.push(zM_row);

      if (first3) {
        spL_x.push(first3.p); spL_y.push(T); spL_z.push(first3.zL);
      }
      if (last3) {
        spV_x.push(last3.p); spV_y.push(T); spV_z.push(last3.zV);
      }
    }

    const traces: any[] = [
      {
        type: 'surface',
        x: x_P,
        y: y_T,
        z: z_Eq,
        surfacecolor: z_Eq,
        cmin: 0,
        cmax: 1,
        colorscale: [
          [0, '#002050'], // Lowest Z (liquid)
          [0.3, '#005EB8'], 
          [0.7, '#4d94ff'],
          [1, '#dbeafe']  // Highest Z (vapor approaching ideal)
        ],
        name: 'Равновесная поверхность',
        showscale: true,
        colorbar: {
          title: 'Коэф. Z',
          thickness: 15,
          len: 0.5,
          x: 0.9,
          tickfont: { size: 10, family: 'Inter, sans-serif' },
          titlefont: { size: 11, family: 'Inter, sans-serif', color: '#6b7280' }
        },
        opacity: 0.95,
        contours: {
          x: { show: false },
          y: { show: false },
        }
      }
    ];

    if (showHysteresis) {
      // Vapor spinodal line
      traces.push({
        type: 'scatter3d',
        mode: 'lines',
        x: spV_x,
        y: spV_y,
        z: spV_z,
        line: { color: '#000000', width: 4 },
        name: 'Спинодаль (пар)',
        showlegend: true
      });
      // Liquid spinodal line
      traces.push({
        type: 'scatter3d',
        mode: 'lines',
        x: spL_x,
        y: spL_y,
        z: spL_z,
        line: { color: '#000000', width: 4 },
        name: 'Спинодаль (жидкость)',
        showlegend: true
      });
    }

    if (showMetastable) {
      traces.push({
        type: 'surface',
        x: x_P,
        y: y_T,
        z: z_Middle,
        colorscale: [[0, '#196e0a'], [1, '#196e0a']],
        name: 'Нестабильное (складка)',
        showscale: false,
        opacity: 0.6,
        contours: {
          x: { show: false },
          y: { show: false },
        }
      });
    }

    // Calculate jump at currentT and currentP
    const { a: currentA, b: currentB } = getMixtureAB(composition, currentT, R_GAS);
    const currentParams: PRParams = { a: currentA, b: currentB, R: R_GAS, T: currentT };
    const currentResult = calculatePRRoots(currentP * MPA_TO_ATM, currentParams);
    
    if (currentResult.Z_vapor !== null && currentResult.Z_liquid !== null) {
      traces.push({
        type: 'scatter3d',
        mode: 'lines+markers',
        x: [currentP, currentP],
        y: [currentT, currentT],
        z: [currentResult.Z_liquid, currentResult.Z_vapor],
        marker: {
          size: 6,
          color: '#ed6c02', // warning color
          symbol: 'circle'
        },
        line: {
          color: '#ed6c02',
          width: 4,
          dash: 'dash'
        },
        name: 'Скачок фаз (выбр. точка)',
        showlegend: true
      });
    }

    return traces;
  }, [composition, pressureRange, temperatureRange, showMetastable, showHysteresis, currentT, currentP]);

  return (
    <div className="w-full h-full min-h-[500px] bg-white rounded-sm border border-[--color-border-secondary] relative shadow-none">
      <Plot
        data={plotData}
        layout={{
          autosize: true,
          margin: { l: 30, r: 30, t: 30, b: 30 },
          scene: {
            xaxis: { 
              title: { text: 'P (МПа)', font: { size: 10, family: 'Inter, sans-serif' } }, 
              backgroundcolor: '#f5f7fa', 
              showbackground: true,
              gridcolor: '#e5e7eb',
              tickfont: { size: 9 }
            },
            yaxis: { 
              title: { text: 'T (К)', font: { size: 10, family: 'Inter, sans-serif' } }, 
              backgroundcolor: '#f5f7fa', 
              showbackground: true,
              gridcolor: '#e5e7eb',
              tickfont: { size: 9 }
            },
            zaxis: { 
              title: { text: 'Z', font: { size: 10, family: 'Inter, sans-serif' } }, 
              backgroundcolor: '#f5f7fa', 
              showbackground: true,
              gridcolor: '#e5e7eb',
              tickfont: { size: 9 }
            },
            camera: {
              eye: { x: -1.6, y: 1.6, z: 0.6 }
            },
            aspectmode: 'cube'
          },
          showlegend: true,
          legend: {
            orientation: 'h',
            yanchor: 'bottom',
            y: 1.02,
            xanchor: 'right',
            x: 1,
            font: { size: 10, family: 'Inter, sans-serif' }
          },
          paper_bgcolor: 'transparent',
          plot_bgcolor: 'transparent'
        }}
        useResizeHandler={true}
        style={{ width: '100%', height: '100%' }}
        config={{ responsive: true, displayModeBar: false }}
      />
    </div>
  );
}
